{
    "LoggerSettings": {
        "Serilog": {
            "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
            "MinimumLevel": {
                "Default": "Information",
                "Override": {
                    "Microsoft": "Warning",
                    "Microsoft.Hosting.Lifetime": "Information",
                    "System": "Warning",
                    "Hangfire": "Information"
                }
            },
            "WriteTo": [
                {
                    "Name": "Console",
                    "Args": {
                        "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
                    }
                },
                {
                    "Name": "File",
                    "Args": {
                        "path": "logs/log-.txt",
                        "rollingInterval": "Day",
                        "shared": true
                    }
                }
            ],
            "Enrich": [
                "FromLogContext",
                "WithMachineName",
                "WithThreadId"
            ]
        }
    }
}