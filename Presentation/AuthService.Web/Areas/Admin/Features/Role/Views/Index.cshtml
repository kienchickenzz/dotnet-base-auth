@model AuthService.Web.Areas.Admin.Features.Role.Models.RoleIndexViewModel
@{
    ViewData["Title"] = "Manage Roles";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mt-4">@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Role
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (!Model.Roles.Any())
            {
                <div class="alert alert-info">
                    No roles found. Create a new role to get started.
                </div>
            }
            else
            {
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Permissions</th>
                            <th width="200">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Model.Roles)
                        {
                            <tr>
                                <td>
                                    @role.Name
                                    @if (role.IsDefault)
                                    {
                                        <span class="badge bg-secondary ms-1">Default</span>
                                    }
                                </td>
                                <td>@(role.Description ?? "-")</td>
                                <td>
                                    <span class="badge bg-info">@role.PermissionCount permissions</span>
                                </td>
                                <td>
                                    <a asp-action="Permissions" asp-route-id="@role.Id"
                                       class="btn btn-sm btn-outline-info" title="Manage Permissions">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@role.Id"
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (!role.IsDefault)
                                    {
                                        <form asp-action="Delete" asp-route-id="@role.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to delete this role?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
