<ul class="navbar-nav">
@if (User.Identity?.IsAuthenticated == true)
{
    <li class="nav-item">
        <span class="nav-link text-light">Hello @User.Identity.Name!</span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="" asp-controller="Login" asp-action="Logout">
            <button type="submit" class="nav-link btn btn-link text-light border-0">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-light" asp-area="" asp-controller="Register" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-light" asp-area="" asp-controller="Login" asp-action="Login">Login</a>
    </li>
}
</ul>
