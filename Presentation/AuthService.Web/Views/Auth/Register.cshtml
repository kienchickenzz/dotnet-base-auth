@model AuthService.Web.Models.Auth.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-dark bg-gradient m-lg-0 py-4">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="py-2 text-white">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>

    @if (Model.ExternalLogins.Any())
    {
        <div class="col-md-12 col-md-offset-2 pt-4 mx-4">
            <section>
                <h3>Use another service to register.</h3>
                <hr />
                <form asp-controller="ExternalLogin" asp-action="Challenge"
                      asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                    <div>
                        <p>
                            @foreach (var provider in Model.ExternalLogins)
                            {
                                <button type="submit" class="btn btn-outline-info"
                                        name="provider" value="@provider.Name"
                                        title="Register using your @provider.DisplayName account">
                                    @provider.DisplayName
                                </button>
                            }
                        </p>
                    </div>
                </form>
            </section>
        </div>
    }

    <hr class="mt-4 pt-4 mb-0 pb-0" />

    <div class="card-body p-4 pt-1">
        <div class="row">
            <div class="col-md-12">
                <form id="registerForm" class="row" asp-action="Register" method="post">
                    <h4 class="border-bottom pb-3 mb-4 text-secondary text-center">Create a new account.</h4>

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3 col-md-6">
                        <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                        <label asp-for="FirstName" class="ms-2 text-muted"></label>
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 col-md-6">
                        <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                        <label asp-for="LastName" class="ms-2 text-muted"></label>
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 col-md-12">
                        <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Email" class="ms-2 text-muted"></label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 col-md-6">
                        <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="Password" />
                        <label asp-for="Password" class="ms-2 text-muted"></label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 col-md-6">
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirm Password" />
                        <label asp-for="ConfirmPassword" class="ms-2 text-muted"></label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3 col-md-12">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                        <label asp-for="PhoneNumber" class="ms-2 text-muted"></label>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="col-12 text-center">
                        <button id="registerSubmit" type="submit" class="w-75 btn btn-lg btn-primary">Register</button>
                    </div>

                    <div class="col-12 text-center mt-3">
                        <p>
                            Already have an account?
                            <a asp-controller="Login" asp-action="Login">Login here</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
